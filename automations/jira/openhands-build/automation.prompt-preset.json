{
  "preset": "prompt",
  "name": "SDLC Demo - Jira OpenHands Build",
  "prompt_file": "prompt.md",
  "trigger": {
    "type": "event",
    "source": "jira",
    "on": "comment_created",
    "filter": "projectKey == '${JIRA_DEMO_PROJECT_KEY}'"
  },
  "repos": [
    {
      "url": "${GITHUB_DEMO_REPO_URL}",
      "provider": "github",
      "ref": "main"
    }
  ],
  "timeout": 900,
  "llm_profile": "sdlc-coding"
}
