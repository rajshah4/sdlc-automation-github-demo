{
  "preset": "prompt",
  "name": "SDLC Demo - GitHub OpenHands QA",
  "prompt_file": "prompt.md",
  "trigger": {
    "type": "event",
    "source": "github",
    "on": ["pull_request.labeled", "issue_comment.created"],
    "filter": "repository.full_name == '${GITHUB_DEMO_REPOSITORY}' && ((pull_request != null && contains(pull_request.labels[].name, 'openhands-qa') && !contains(pull_request.labels[].name, 'openhands:in-progress')) || (issue.pull_request != null && (contains(issue.labels[].name, 'openhands-qa') || icontains(comment.body, 'openhands-qa')) && !contains(issue.labels[].name, 'openhands:in-progress')))"
  },
  "repos": [
    {
      "url": "${GITHUB_DEMO_REPO_URL}",
      "provider": "github",
      "ref": "main"
    }
  ],
  "timeout": 600,
  "llm_profile": "sdlc-coding"
}
